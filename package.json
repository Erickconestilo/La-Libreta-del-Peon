{
  "name": "topofield-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "mobile:start": "npm run start --workspace apps/mobile",
    "mobile:android": "npm run android --workspace apps/mobile",
    "mobile:web": "npm run web --workspace apps/mobile",
    "mobile:build-local-android": "powershell -ExecutionPolicy Bypass -File scripts/build-local-android.ps1",
    "backend:dev": "npm run dev --workspace apps/backend",
    "backend:build": "npm run build --workspace apps/backend",
    "verify:pre-apk": "node scripts/verify-pre-apk.mjs"
  }
}
