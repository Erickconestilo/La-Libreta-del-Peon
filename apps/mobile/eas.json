{
  "cli": {
    "version": ">= 16.20.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://la-libreta-del-peon-1.onrender.com/api/v1",
        "EXPO_PUBLIC_GUEST_PUBLIC_TOKEN": "un-token-publico-largo-y-dificil"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
